# ============================================
# NEXUS IA — Variables de Entorno
# Copiar este archivo a .env.local y rellenar
# con los valores reales. NUNCA commitear .env.local
# ============================================
# Copia este fichero como .env.local para desarrollo local:
#   cp .env.example .env.local
#
# NUNCA subas .env.local al repositorio. Está en .gitignore.
# En Vercel, configura estas variables en Settings > Environment Variables.
# =============================================================================


# =============================================================================
# SUPABASE
# =============================================================================
# Encuentra estas claves en: Supabase Dashboard > Settings > API

# URL pública del proyecto (safe para el frontend)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anónima pública (safe para el frontend, respeta RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx

# Clave de servicio (¡SOLO en servidor! Bypassa RLS — tratar como contraseña)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx


# =============================================================================
# RESEND — Envío de Emails Transaccionales
# =============================================================================
# Crea una cuenta en https://resend.com y genera una API key
# Verifica el dominio nexusia.es en Resend antes de enviar emails reales

# API Key de Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email remitente verificado en Resend (debe pertenecer al dominio verificado)
RESEND_FROM_EMAIL=noreply@nexusia.es

# Email del equipo comercial que recibe los nuevos leads
RESEND_TEAM_EMAIL=hola@nexusia.es

# Email adicional con copia (opcional, puede ser el director comercial)
RESEND_CC_EMAIL=


# =============================================================================
# N8N — Automatización de Workflows
# =============================================================================
# Si usas n8n Cloud: https://app.n8n.cloud
# Si usas n8n self-hosted con Docker: http://tu-servidor:5678

# URL del webhook de nuevos leads (se obtiene al crear el nodo Webhook en n8n)
N8N_WEBHOOK_URL=https://tu-instancia.app.n8n.cloud/webhook/nuevo-lead

# Secreto compartido para verificar que el webhook viene de tu web (Bearer token)
# Genera uno seguro con: openssl rand -hex 32
N8N_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL del webhook de seguimiento (flow 2)
N8N_WEBHOOK_FOLLOWUP_URL=https://tu-instancia.app.n8n.cloud/webhook/seguimiento-lead


# =============================================================================
# CONFIGURACIÓN DEL SITIO
# =============================================================================

# URL pública del sitio (sin trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.nexusia.es

# Nombre de la empresa (se usa en emails, meta tags, etc.)
NEXT_PUBLIC_COMPANY_NAME=Nexus IA

# Email público de contacto (aparece en la web)
NEXT_PUBLIC_COMPANY_EMAIL=hola@nexusia.es

# Teléfono de contacto (formato E.164 para WhatsApp links)
NEXT_PUBLIC_COMPANY_PHONE=+34900000000

# Dirección física (para schema.org y aviso legal)
NEXT_PUBLIC_COMPANY_ADDRESS=Calle Gran Vía 28, 28013 Madrid

# CIF/NIF de la empresa (para aviso legal y facturas)
NEXT_PUBLIC_COMPANY_CIF=B-XXXXXXXXX


# =============================================================================
# CALENDLY — Reserva de Reuniones
# =============================================================================
# Crea un tipo de evento "Diagnóstico Gratuito 30min" en Calendly
# y pega aquí la URL del evento

NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/nexusia/diagnostico-gratuito

# API Key de Calendly (para verificar reuniones desde n8n)
# Settings > Integrations > API & Webhooks
CALENDLY_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx


# =============================================================================
# ANALYTICS Y MONITORIZACIÓN
# =============================================================================

# Google Analytics 4 — Measurement ID
# Se obtiene en GA4 > Admin > Data Streams > tu stream web
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Hotjar (opcional, para mapas de calor)
NEXT_PUBLIC_HOTJAR_ID=


# =============================================================================
# REDES SOCIALES
# =============================================================================
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/nexusia.es
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/nexusia
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/nexusia_es
NEXT_PUBLIC_YOUTUBE_URL=


# =============================================================================
# SEGURIDAD
# =============================================================================

# Secret para firmar JWT internos (si implementas área de clientes)
# Genera con: openssl rand -base64 64
NEXTAUTH_SECRET=

NEXTAUTH_URL=https://www.nexusia.es


# =============================================================================
# DESARROLLO LOCAL
# =============================================================================

NODE_ENV=development
DEBUG_BOT=false
EMAIL_DRY_RUN=true
N8N_DRY_RUN=true
